# Google Cloud Configuration
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1

# Storage
DEFAULT_BUCKET=gs://dpgen-shared
RENDERER_BUCKET=gs://dpgen-renderer

# API Keys
CSE_API_KEY=your-custom-search-api-key
CSE_CX=your-search-engine-id

# Platform API Keys (for publishing)
YOUTUBE_API_KEY=your-youtube-api-key
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
META_APP_ID=your-facebook-app-id
META_APP_SECRET=your-facebook-app-secret
META_ACCESS_TOKEN=your-instagram-access-token

# Pipedream
PIPEDREAM_API_KEY=your-pipedream-api-key
PIPEDREAM_ORG_ID=your-pipedream-org-id

# Safety & Compliance
PERSPECTIVE_API_KEY=your-perspective-api-key
SAFETY_THRESHOLD=0.7

# Monitoring
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ERROR_NOTIFICATION_EMAIL=admin@example.com

# Scheduling
TIMEZONE=America/Phoenix
DEFAULT_CADENCE_WINDOWS=12:30,19:30

# Quotas & Limits
MAX_DAILY_VIDEOS_PER_CHANNEL=2
MAX_CONCURRENT_RENDERS=3
VEO_REQUEST_QUOTA=100
IMAGEN_REQUEST_QUOTA=500
GEMINI_TOKEN_QUOTA=1000000